{
  "db_name": "PostgreSQL",
  "query": "\nWITH inserted AS (\n    INSERT INTO user_data_scripts_tags (script_id, tag_id)\n    SELECT $1, unnest($2::uuid[])\n    RETURNING script_id, tag_id\n)\nSELECT t.id, t.name, t.color\nFROM inserted i\nJOIN user_tags t ON i.tag_id = t.id\nORDER BY t.name ASC\n            ",
