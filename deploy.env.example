# Copy to deploy.env and fill in. deploy.env is gitignored.

# Private Docker registry hostname (e.g., registry.example.com)
DEPLOY_REGISTRY=

# Platform for docker buildx (default: linux/arm64)
DEPLOY_PLATFORM=linux/arm64

# Tag used for the dev environment (default: latest)
DEPLOY_DEV_TAG=latest

# Tag used for the production environment (e.g., 1.0.0-beta.1)
DEPLOY_PROD_TAG=

# Tag for the Camoufox web scraper image, versioned independently (e.g., v142)
DEPLOY_CAMOUFOX_TAG=
